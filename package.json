{
  "name": "mosaic",
  "productName": "Mosaic",
  "version": "0.1.5",
  "description": "A non-destructive Electron mosaic editor for local images and clipboard workflows.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node scripts/start-dev.mjs",
    "prepare-build-assets": "node scripts/prepare-build-assets.mjs",
    "dist": "npm run dist:mac && npm run dist:win",
    "dist:mac": "npm run prepare-build-assets && electron-builder --mac dmg zip",
    "dist:win": "npm run prepare-build-assets && electron-builder --win nsis --x64",
    "publish:github": "npm run prepare-build-assets && electron-builder --mac dmg zip --win nsis --x64 --publish always",
    "test": "node --test",
    "check": "npm test"
  },
  "keywords": [
    "electron",
    "mosaic",
    "redaction",
    "canvas"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "build": {
    "appId": "com.hololee.mosaic",
    "productName": "Mosaic",
    "asar": true,
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "zip"
        }
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hololee",
        "repo": "mosaic",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "gifenc": "^1.0.3",
    "gifuct-js": "^2.1.2"
  }
}
